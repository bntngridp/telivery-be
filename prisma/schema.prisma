generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model detail_pesanan_layanan {
  id_detail   Int      @id @default(autoincrement())
  pesanan_id  Int?
  layanan_id  Int?
  jumlah_item Int?
  subtotal    Decimal? @db.Decimal(12, 2)
  pesanan     pesanan? @relation(fields: [pesanan_id], references: [pesanan_id], onDelete: Restrict, onUpdate: Restrict, map: "detail_pesanan_layanan_ibfk_1")
  layanan     layanan? @relation(fields: [layanan_id], references: [layanan_id], onDelete: Restrict, onUpdate: Restrict, map: "detail_pesanan_layanan_ibfk_2")

  @@unique([pesanan_id, layanan_id], map: "pesanan_id")
  @@index([layanan_id], map: "layanan_id")
}

model detail_pesanan_produk {
  id_detail   Int      @id @default(autoincrement())
  pesanan_id  Int?
  produk_id   Int?
  jumlah_item Int?
  subtotal    Decimal? @db.Decimal(12, 2)
  pesanan     pesanan? @relation(fields: [pesanan_id], references: [pesanan_id], onDelete: Restrict, onUpdate: Restrict, map: "detail_pesanan_produk_ibfk_1")
  produk      produk?  @relation(fields: [produk_id], references: [produk_id], onDelete: Restrict, onUpdate: Restrict, map: "detail_pesanan_produk_ibfk_2")

  @@unique([pesanan_id, produk_id], map: "pesanan_id")
  @@index([produk_id], map: "produk_id")
}

model dompet_mitra {
  id_dompet      Int              @id @default(autoincrement())
  mitra_id       Int?
  saldo          Decimal?         @db.Decimal(12, 2)
  status_dompet  String?          @db.VarChar(50)
  tanggal_dibuat DateTime?        @db.DateTime(0)
  tanggal_diubah DateTime?        @db.DateTime(0)
  penjual        penjual?         @relation(fields: [mitra_id], references: [mitra_id], onDelete: Restrict, onUpdate: Restrict, map: "dompet_mitra_ibfk_1")
  riwayat_dompet riwayat_dompet[]

  @@index([mitra_id], map: "mitra_id")
}

model kategori {
  id_kategori        Int      @id @default(autoincrement())
  nama_kategori      String?  @unique(map: "nama_kategori") @db.VarChar(100)
  deskripsi_kategori String?  @db.Text
  produk             produk[]
}

model layanan {
  layanan_id             Int                      @id @default(autoincrement())
  mitra_id               Int?
  nama_layanan           String?                  @db.VarChar(100)
  harga                  Decimal?                 @db.Decimal(12, 2)
  jenis_layanan          String?                  @db.VarChar(100)
  estimasi_durasi        String?                  @db.VarChar(50)
  catatan                String?                  @db.Text
  cart                   cart[]
  detail_pesanan_layanan detail_pesanan_layanan[]
  penjual                penjual?                 @relation(fields: [mitra_id], references: [mitra_id], onDelete: Restrict, onUpdate: Restrict, map: "layanan_ibfk_1")

  @@index([mitra_id], map: "mitra_id")
}

model notifikasi {
  notifikasi_id Int       @id @default(autoincrement())
  user_id       Int?
  mitra_id      Int?
  isi_pesan     String?   @db.Text
  waktu_kirim   DateTime? @db.DateTime(0)
  tipe          String?   @db.VarChar(50)
  status_dibaca Boolean?
  pembeli       pembeli?  @relation("PembeliNotifikasi", fields: [user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "notifikasi_ibfk_1")
  penjual       penjual?  @relation(fields: [mitra_id], references: [mitra_id], onDelete: Restrict, onUpdate: Restrict, map: "notifikasi_ibfk_2")

  @@index([mitra_id], map: "mitra_id")
  @@index([user_id], map: "user_id")
}

model pembayaran {
  pembayaran_id     Int       @id @default(autoincrement())
  pesanan_id        Int?
  status_pembayaran String?   @db.VarChar(50)
  metode_pembayaran String?   @db.VarChar(50)
  waktu_pembayaran  DateTime? @db.DateTime(0)
  bukti_bayar       String?   @db.Text
  catatan_penjual   String?   @db.Text
  // Midtrans Snap fields
  midtrans_order_id String?   @unique @db.VarChar(100)
  snap_token        String?   @db.Text
  payment_type      String?   @db.VarChar(50)
  paid_at           DateTime? @db.DateTime(0)
  midtrans_response Json?
  pesanan           pesanan?  @relation(fields: [pesanan_id], references: [pesanan_id], onDelete: Restrict, onUpdate: Restrict, map: "pembayaran_ibfk_1")

  @@index([pesanan_id], map: "pembayaran_pesanan_id_fkey")
  @@index([status_pembayaran], map: "pembayaran_status_idx")
}

model pembeli {
  user_id          Int             @id @default(autoincrement())
  email            String?         @db.VarChar(100)
  password         String?         @db.VarChar(255)
  domicile         String?         @db.VarChar(100)
  faculty          String?         @db.VarChar(100)
  major            String?         @db.VarChar(100)
  delivery_address String?         @db.Text
  phone_number     String?         @db.VarChar(20)
  full_name        String?         @db.VarChar(100)
  birth_date       DateTime?
  last_login_at    DateTime?
  alamat           alamat[]
  cart             cart[]
  notifications    notifikasi[]    @relation("PembeliNotifikasi")
  orders           pesanan[]       @relation("PembeliPesanan")
  refresh_tokens   refresh_token[]
}

model penjual {
  mitra_id          Int             @id @default(autoincrement())
  phone_number      String?         @db.VarChar(20)
  email             String?         @db.VarChar(100)
  password          String?         @db.VarChar(255)
  jenis_usaha       String?         @db.VarChar(50)
  foto_ktp_pemilik  String?         @db.Text
  alamat_toko       String?         @db.Text
  foto_pemilik      String?         @db.Text
  status_verifikasi String?         @db.VarChar(50)
  nama_pemilik      String?         @db.VarChar(100)
  nama_toko         String?         @unique(map: "nama_toko") @db.VarChar(100)
  deskripsi_toko    String?         @db.Text
  jam_oprasional    String?         @db.VarChar(50)
  verifikasi_toko   Boolean?
  status_toko       String?         @db.VarChar(50)
  role_penjual      String?         @db.VarChar(50)
  waktu_dibuat      DateTime?       @db.DateTime(0)
  last_login_at     DateTime?       @db.DateTime(0)
  dompet_mitra      dompet_mitra[]
  layanan           layanan[]
  notifikasi        notifikasi[]
  pesanan           pesanan[]
  produk            produk[]
  refresh_tokens    refresh_token[]
}

model pesanan {
  pesanan_id             Int                      @id @default(autoincrement())
  user_id                Int?
  mitra_id               Int?
  total_harga            Decimal?                 @db.Decimal(12, 2)
  ongkir                 Decimal?                 @default(0) @db.Decimal(12, 2)
  alamat_pengiriman      String?                  @db.Text
  alamat_id              Int?
  status_pesanan         String?                  @db.VarChar(50)
  metode_pembayaran      String?                  @db.VarChar(50)
  waktu_pesan            DateTime?                @db.DateTime(0)
  waktu_dikirim          DateTime?                @db.DateTime(0)
  waktu_diterima         DateTime?                @db.DateTime(0)
  detail_pesanan_layanan detail_pesanan_layanan[]
  detail_pesanan_produk  detail_pesanan_produk[]
  pembayaran             pembayaran[]
  alamat_ref             alamat?                  @relation(fields: [alamat_id], references: [alamat_id], onDelete: SetNull, onUpdate: Restrict, map: "pesanan_alamat_fk")
  pembeli                pembeli?                 @relation("PembeliPesanan", fields: [user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "pesanan_ibfk_1")
  penjual                penjual?                 @relation(fields: [mitra_id], references: [mitra_id], onDelete: Restrict, onUpdate: Restrict, map: "pesanan_ibfk_2")
  ulasan                 ulasan[]

  @@index([mitra_id], map: "mitra_id")
  @@index([user_id], map: "user_id")
  @@index([alamat_id], map: "pesanan_alamat_idx")
}

model produk {
  produk_id             Int                     @id @default(autoincrement())
  mitra_id              Int?
  id_kategori           Int?
  nama_produk           String?                 @db.VarChar(100)
  harga                 Decimal?                @db.Decimal(12, 2)
  foto                  String?                 @db.Text
  status_ketersediaan   Boolean?
  stok_produk           Int?
  cart                  cart[]
  detail_pesanan_produk detail_pesanan_produk[]
  penjual               penjual?                @relation(fields: [mitra_id], references: [mitra_id], onDelete: Restrict, onUpdate: Restrict, map: "produk_ibfk_1")
  kategori              kategori?               @relation(fields: [id_kategori], references: [id_kategori], onDelete: Restrict, onUpdate: Restrict, map: "produk_ibfk_2")

  @@index([id_kategori], map: "id_kategori")
  @@index([mitra_id], map: "mitra_id")
}

model riwayat_dompet {
  id_transaksi        Int           @id @default(autoincrement())
  id_dompet           Int?
  jenis_transaksi     String?       @db.VarChar(50)
  jumlah_diterima     Decimal?      @db.Decimal(12, 2)
  deskripsi_transaksi String?       @db.Text
  waktu_transaksi     DateTime?     @db.DateTime(0)
  dompet_mitra        dompet_mitra? @relation(fields: [id_dompet], references: [id_dompet], onDelete: Restrict, onUpdate: Restrict, map: "riwayat_dompet_ibfk_1")

  @@index([id_dompet], map: "id_dompet")
}

model ulasan {
  id_ulasan    Int       @id @default(autoincrement())
  id_pesanan   Int?
  rating       Int?
  komentar     String?   @db.Text
  waktu_ulasan DateTime? @db.DateTime(0)
  pesanan      pesanan?  @relation(fields: [id_pesanan], references: [pesanan_id], onDelete: Restrict, onUpdate: Restrict, map: "ulasan_ibfk_1")

  @@index([id_pesanan], map: "id_pesanan")
}

model otp_verify {
  id        Int      @id @default(autoincrement())
  phone     String   @db.VarChar(20)
  otp       String   @db.VarChar(5)
  expiredAt DateTime
  createdAt DateTime @default(now())
}

model cart {
  cart_id    Int      @id @default(autoincrement())
  user_id    Int
  produk_id  Int?
  layanan_id Int?
  jumlah     Int
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @updatedAt @db.DateTime(0)

  pembeli pembeli? @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "cart_ibfk_1")
  produk  produk?  @relation(fields: [produk_id], references: [produk_id], onDelete: Cascade, onUpdate: Restrict, map: "cart_ibfk_2")
  layanan layanan? @relation(fields: [layanan_id], references: [layanan_id], onDelete: Cascade, onUpdate: Restrict, map: "cart_ibfk_3")

  @@unique([user_id, produk_id], map: "cart_user_produk_unique")
  @@unique([user_id, layanan_id], map: "cart_user_layanan_unique")
  @@index([user_id], map: "cart_user_id_fkey")
  @@index([produk_id], map: "cart_produk_id_fkey")
  @@index([layanan_id], map: "cart_layanan_id_fkey")
}

model refresh_token {
  token_id   Int       @id @default(autoincrement())
  user_id    Int?
  mitra_id   Int?
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.DateTime(0)
  revoked_at DateTime? @db.DateTime(0)
  created_at DateTime  @default(now()) @db.DateTime(0)
  user_agent String?   @db.VarChar(255)

  pembeli pembeli? @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "refresh_token_user_fk")
  penjual penjual? @relation(fields: [mitra_id], references: [mitra_id], onDelete: Cascade, onUpdate: Restrict, map: "refresh_token_mitra_fk")

  @@index([user_id], map: "refresh_token_user_idx")
  @@index([mitra_id], map: "refresh_token_mitra_idx")
  @@index([expires_at], map: "refresh_token_exp_idx")
}

model alamat {
  alamat_id      Int      @id @default(autoincrement())
  user_id        Int
  label          String   @db.VarChar(50)
  alamat_lengkap String   @db.Text
  catatan        String?  @db.Text
  latitude       Decimal? @db.Decimal(10, 7)
  longitude      Decimal? @db.Decimal(10, 7)
  is_primary     Boolean  @default(false)
  created_at     DateTime @default(now()) @db.DateTime(0)
  updated_at     DateTime @updatedAt @db.DateTime(0)

  pembeli pembeli   @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: Restrict, map: "alamat_user_fk")
  pesanan pesanan[]

  @@index([user_id], map: "alamat_user_idx")
  @@index([user_id, is_primary], map: "alamat_user_primary_idx")
}
