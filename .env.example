DATABASE_URL="mysql://root@127.0.0.1:3306/telivery"
PORT=3000
JWT_SECRET=cheva_telivery_dev_secret_change_me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# Midtrans Snap — sandbox creds for local dev only.
# Get your own from https://dashboard.sandbox.midtrans.com/
MIDTRANS_SERVER_KEY=SB-Mid-server-DUMMY
MIDTRANS_CLIENT_KEY=SB-Mid-client-DUMMY
MIDTRANS_IS_PRODUCTION=false
# Public URL Midtrans POSTs to. Use ngrok for local: `ngrok http 3000`
MIDTRANS_NOTIFICATION_URL=https://YOUR-NGROK-ID.ngrok-free.app/api/payments/midtrans/webhook

# Refresh token (#13)
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_ROUNDS=10

# Email — Mailtrap sandbox for dev (https://mailtrap.io/)
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Cheva Telivery <noreply@telivery.local>"
