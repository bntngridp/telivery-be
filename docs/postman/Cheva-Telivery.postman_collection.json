{
  "info": {
    "name": "Cheva-Telivery API",
    "description": "Backend API untuk marketplace delivery kampus.\n\nBase URL: `http://localhost:3000`\n\n**Auth Flow:**\n1. Register atau request OTP\n2. Verify OTP → dapat JWT token\n3. Gunakan token di header `Authorization: Bearer <token>`\n\n**Roles:**\n- `pembeli` (buyer) — token dari `/api/auth/buyer/verify-otp`\n- `penjual` (seller) — token dari `/api/auth/seller/login`\n- `admin` — token dari `/api/auth/admin/login`\n\n**Dokumentasi lengkap:** lihat `issues/008-notification.md`, `011-cart-checkout.md`, dll di repo.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{buyerToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "buyerToken", "value": "", "type": "string" },
    { "key": "sellerToken", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "buyerId", "value": "", "type": "string" },
    { "key": "sellerId", "value": "", "type": "string" },
    { "key": "produkId", "value": "", "type": "string" },
    { "key": "layananId", "value": "", "type": "string" },
    { "key": "pesananId", "value": "", "type": "string" },
    { "key": "pembayaranId", "value": "", "type": "string" },
    { "key": "storeId", "value": "", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" },
    { "key": "cartItemId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "01. System",
      "item": [
        {
          "name": "Welcome",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] }
          }
        },
        {
          "name": "Health Check (DB ping)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "02. Auth — Buyer",
      "item": [
        {
          "name": "Register Buyer (creates user + sends OTP)",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [""], "type": "text/javascript" }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Budi Test\",\n  \"phoneNumber\": \"081111111111\",\n  \"birthDate\": \"2000-05-15\",\n  \"domicile\": \"Jakarta\",\n  \"faculty\": \"FTI\",\n  \"major\": \"Teknik Informatika\",\n  \"address\": \"Jl. Test No. 1, Jakarta\",\n  \"email\": \"budi.test@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/buyer/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "buyer", "register"] }
          }
        },
        {
          "name": "Request OTP Login (rate limited 5/15min)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"081111111111\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/buyer/request-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "buyer", "request-otp"] }
          }
        },
        {
          "name": "Verify OTP Login (returns JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();\nif (json.data && json.data.token) {\n    pm.collectionVariables.set('buyerToken', json.data.token);\n    const decoded = json.data.token.split('.')[1];\n    const payload = JSON.parse(atob(decoded));\n    pm.collectionVariables.set('buyerId', payload.id);\n    console.log('buyerToken saved, id:', payload.id);\n}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"081111111111\",\n  \"otp\": \"12345\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/buyer/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "buyer", "verify-otp"] }
          }
        }
      ]
    },
    {
      "name": "03. Auth — Seller",
      "item": [
        {
          "name": "Request Seller OTP (rate limited)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"082222222222\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/request-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "request-otp"] }
          }
        },
        {
          "name": "Verify OTP + Register Seller (returns JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();\nif (json.data && json.data.token) {\n    pm.collectionVariables.set('sellerToken', json.data.token);\n    const decoded = json.data.token.split('.')[1];\n    const payload = JSON.parse(atob(decoded));\n    pm.collectionVariables.set('sellerId', payload.sellerId);\n    console.log('sellerToken saved, id:', payload.sellerId);\n}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"082222222222\",\n  \"otp\": \"12345\",\n  \"email\": \"siti.test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/verify-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "verify-otp"] }
          }
        },
        {
          "name": "Register Store (multipart, requires JWT)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "businessType", "value": "makanan", "type": "text" },
                { "key": "storeName", "value": "Toko Test", "type": "text" },
                { "key": "storeAddress", "value": "Jl. Toko No. 1, Jakarta", "type": "text" },
                { "key": "ownerKtpPhoto", "src": "/path/to/ktp.jpg", "type": "file" },
                { "key": "ownerFacePhoto", "src": "/path/to/face.jpg", "type": "file" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/register-store", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "register-store"] }
          }
        },
        {
          "name": "Seller Login (email + password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();\nif (json.data && json.data.token) {\n    pm.collectionVariables.set('sellerToken', json.data.token);\n    const decoded = json.data.token.split('.')[1];\n    const payload = JSON.parse(atob(decoded));\n    pm.collectionVariables.set('sellerId', payload.sellerId);\n    console.log('sellerToken refreshed, id:', payload.sellerId);\n}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"siti.test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "login"] }
          }
        },
        {
          "name": "Forgot Password (rate limited)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"siti.test@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "forgot-password"] }
          }
        },
        {
          "name": "Verify Reset OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"siti.test@example.com\",\n  \"otp\": \"12345\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/verify-reset-otp", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "verify-reset-otp"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"siti.test@example.com\",\n  \"otp\": \"12345\",\n  \"newPassword\": \"newPassword456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/seller/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "auth", "seller", "reset-password"] }
          }
        }
      ]
    },
